# ── LM Studio (local, free) ──────────────────────────────
# LM Studio Developer tab → Local Server → Status: Running
# REST API v1 must be in Anthropic-compatible mode.
# The key is not validated by LM Studio; any value works.
ANTHROPIC_API_KEY=lm-studio
ANTHROPIC_BASE_URL=http://127.0.0.1:1234
MAIN_MODEL=google/gemma-4-e4b

# ── BYOK (official Anthropic API) ────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx
# (leave ANTHROPIC_BASE_URL unset)
# MAIN_MODEL=claude-sonnet-4-6
